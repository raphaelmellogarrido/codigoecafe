# Variáveis de ambiente usadas neste projeto.
# Copia para .env (frontend) e configura as equivalentes no painel do serviço
# que hospedar a API (ex.: Render) — nunca commites os valores reais.

# --- Frontend (Vite) ---
# URL da API publicada. Em desenvolvimento local podes deixar vazio
# (o Vite faz proxy de /api para http://localhost:4000 — ver vite.config.js).
VITE_API_URL=

# --- Backend (server/) ---
# Chave usada para assinar os tokens JWT. Em produção, define uma string
# longa e aleatória diferente da usada em desenvolvimento.
JWT_SECRET=
